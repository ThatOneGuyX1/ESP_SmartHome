# Node A Firmware — Default Configuration
# ESP32 Feather V2 (ESP32-PICO-MINI-02)

# Wi-Fi (STA mode for ESP-NOW, no AP connection)
CONFIG_ESP_WIFI_MODE_STA=y

# Mock sensors enabled by default (no hardware needed)
CONFIG_USE_MOCK_SENSORS=y

# Sampling intervals
CONFIG_SENSOR_SAMPLE_INTERVAL_MS=30000
CONFIG_HEALTH_REPORT_INTERVAL_MS=120000

# Logging
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# FreeRTOS
CONFIG_FREERTOS_HZ=1000
